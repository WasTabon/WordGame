  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "\u2022 Swipe across adjacent hexagon letters to form words.\n\n\u2022
    Every word must <b>begin on a cell next to an empty space</b>.\n\n\u2022 Valid
    words must exist in the dictionary.\n\n\u2022 After a valid word, used letters
    turn into new empty spaces \u2014 the board grows outward.\n\n\u2022 Cells showing
    a <b>number</b> require a word of at least that length.\n\n\u2022 <b>EXPLORE</b>
    mode: play freely, aim for the highest score.\n\n\u2022 <b>ESCAPE</b> mode: reach
    the edge before time runs out."
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
